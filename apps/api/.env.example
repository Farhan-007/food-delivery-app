# ============================================================
# apps/api — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL + PostGIS)
DATABASE_URL=postgresql://foodhub:foodhub_dev_pass@localhost:5432/foodhub_db

# Redis (Valkey)
REDIS_URL=redis://localhost:6379

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=food-delivery
MINIO_USE_SSL=false

# Better-Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=change_me_to_a_random_32_char_string_minimum
API_URL=http://localhost:3001

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email — Resend (optional, falls back to console)
# RESEND_API_KEY=re_...
# Or SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=noreply@foodhub.dev

# Expo Push Notifications (optional)
# EXPO_ACCESS_TOKEN=

# Platform Config
PLATFORM_FEE_PERCENT=5
TAX_PERCENT=8
DEFAULT_CURRENCY=USD
